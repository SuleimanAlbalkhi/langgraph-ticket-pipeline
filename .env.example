# Beispiel-Konfiguration. Kopieren nach .env (gitignored) und Werte setzen:
#   cp .env.example .env

# --- n8n ---
# Verschlüsselungsschlüssel für gespeicherte Credentials. PFLICHT (docker compose
# bricht sonst mit klarer Meldung ab). Stabil halten und sichern — bei Verlust sind
# verschlüsselte Credentials nicht mehr lesbar.
# Erzeugen:  python -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=

# --- FastAPI ---
# Maximale Anzahl gleichzeitig laufender Analysen (Überlastschutz, schützt die GPU).
# Default 2 ist auf eine kleine GPU (~4 GB VRAM, qwen2.5:3b) abgestimmt: eine einzelne
# Analyse löst intern bereits bis zu 3 parallele Classifier-Votes aus. Auf größerer
# Hardware (mehr VRAM / mehrere GPUs) kann der Wert erhöht werden.
MAX_CONCURRENT_ANALYSES=2

# --- Ollama (HOST-seitig, NICHT im Container!) ---
# Ollama läuft hier nicht containerisiert, sondern als `ollama serve` auf dem Host.
# Der tatsächliche GPU-Parallelitätsgrad wird deshalb über eine Host-Umgebungsvariable
# gesteuert, NICHT über diese .env oder docker compose:
#
#   OLLAMA_NUM_PARALLEL — Anzahl gleichzeitig pro Modell verarbeiteter Requests.
#
# Auf ~4 GB VRAM mit qwen2.5:3b ist 2 ein guter Startwert (1, falls der VRAM knapp wird;
# 3 nur, wenn genug VRAM frei ist, damit ein komplettes Vote-Triple zusammen läuft).
# Setzen, dann Ollama neu starten — z. B. unter Windows (PowerShell, dauerhaft):
#
#   setx OLLAMA_NUM_PARALLEL 2     # danach neues Terminal oeffnen + Ollama-Neustart
#
# 
