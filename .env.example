# Beispiel-Konfiguration. Kopieren nach .env (gitignored) und Werte setzen:
#   cp .env.example .env

# --- n8n ---
# Verschlüsselungsschlüssel für gespeicherte Credentials. PFLICHT (docker compose
# bricht sonst mit klarer Meldung ab). Stabil halten und sichern — bei Verlust sind
# verschlüsselte Credentials nicht mehr lesbar.
# Erzeugen:  python -c "import secrets; print(secrets.token_hex(32))"
N8N_ENCRYPTION_KEY=

# --- FastAPI ---
# Maximale Anzahl gleichzeitig laufender Analysen (Überlastschutz, schützt die GPU).
MAX_CONCURRENT_ANALYSES=4
